// WebForge Prisma Schema
// All state is in SQLite via Prisma — no more Python, no more flat JSON files.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tasks (Kanban board) ──

model Task {
  id          String   @id
  title       String
  description String   @default("")
  type        String   // feature, bugfix, refactor, test, docs
  area        String   @default("")
  effort      String   @default("M") // S, M, L
  status      String   @default("backlog") // backlog, todo, doing, done, blocked
  owner       String?
  blockReason String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  messages    Message[]
  runs        Run[]
  decisions   Decision[]

  @@index([status])
  @@index([owner])
  @@index([type])
}

// ── Messages (Mailbox — inter-agent communication) ──

model Message {
  id         String   @id
  parentId   String?
  fromAgent  String
  toAgent    String
  type       String   // TASK_ASSIGNED, TASK_ACK, TASK_PROGRESS, TASK_DONE, etc.
  subject    String   @default("")
  body       String
  taskId     String?
  priority   Int      @default(0) // 0=normal, 1=high, 2=urgent
  status     String   @default("unread") // unread, read, acked, replied, archived
  readAt     DateTime?
  ackedAt    DateTime?
  createdAt  DateTime @default(now())

  task       Task?    @relation(fields: [taskId], references: [id])
  parent     Message? @relation("MessageThread", fields: [parentId], references: [id])
  replies    Message[] @relation("MessageThread")

  @@index([toAgent, status])
  @@index([taskId])
  @@index([parentId])
}

// ── Runs (Agent execution — for crash recovery) ──

model Run {
  id         String   @id
  taskId     String?
  agent      String
  pid        Int?
  trigger    String?
  status     String   @default("pending") // pending, running, completed, failed
  startedAt  DateTime @default(now())
  endedAt    DateTime?
  exitCode   Int?
  error      String?
  runDir     String?

  task       Task?    @relation(fields: [taskId], references: [id])
  checkpoints Checkpoint[]

  @@index([taskId])
  @@index([status])
  @@index([agent])
}

// ── Checkpoints (for resume after crash) ──

model Checkpoint {
  id         Int      @id @default(autoincrement())
  runId      String
  step       String
  stateJson  String
  timestamp  DateTime @default(now())

  run        Run      @relation(fields: [runId], references: [id])

  @@index([runId])
}

// ── Decisions (ADR-style log) ──

model Decision {
  id         Int      @id @default(autoincrement())
  taskId     String?
  agent      String
  decision   String
  rationale  String?
  timestamp  DateTime @default(now())

  task       Task?    @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

// ── Agent States (real-time tracking for UI + watchdog) ──

model AgentState {
  agent        String   @id
  state        String   @default("idle") // idle, active, waiting, sleeping, no_response
  task         String?  // current task ID being worked on
  retries      Int      @default(0) // check-in retry count for current subordinate
  watching     String?  // JSON array of subordinates being watched [{name, taskId, retries, lastCheckin}]
  lastActive   DateTime @default(now())
  lastCheckin  DateTime? // last time this agent was checked on by its superior
  updatedAt    DateTime @updatedAt
}

// ── Sequence Counters (atomic ID generation) ──

model SequenceCounter {
  name       String   @id
  nextValue  Int      @default(1)
}

// ── Keep existing models ──

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
